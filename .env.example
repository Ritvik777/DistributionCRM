ANTHROPIC_API_KEY=your-anthropic-api-key-here
QDRANT_URL=your-qdrant-cloud-url-here
QDRANT_API_KEY=your-qdrant-api-key-here
APOLLO_API_KEY=your-apollo-api-key-here
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=you@yourcompany.com
BREVO_FROM_NAME=TradeFlow Team
ANTHROPIC_MODEL=claude-haiku-4-5
# Vision model for component photo captioning + re-ranking (use a vision-capable Claude model)
VISION_MODEL=claude-haiku-4-5
# Fast model for indexing captions; accurate model for match re-ranking
VISION_CAPTION_MODEL=claude-haiku-4-5
VISION_RERANK_MODEL=claude-haiku-4-5
# CLIP model for component image visual search (sentence-transformers)
CLIP_MODEL_NAME=clip-ViT-B-32
COMPONENT_COLLECTION_NAME=Rama_components
COMPONENT_RERANK_POOL=3
COMPONENT_CLIP_CANDIDATES=8
# Optional public base URL for catalog images in outreach emails (e.g. https://cdn.example.com/components)
# Links appear as "View full-resolution catalog photo" when set; image is always embedded inline when available.
# Brevo does NOT support base64/CID inline images — a public https URL is required for <img> in the body.
CATALOG_IMAGE_TEMP_UPLOAD=true
GALILEO_API_KEY=your-galileo-api-key-here
GALILEO_PROJECT=your-galileo-project-name
GALILEO_LOG_STREAM=your-galileo-stream-name
GALILEO_EXPERIMENT_NAME=your-galileo-experiment-name
GALILEO_DEBUG_URLS=true

# Salesforce CRM — uses your TypeScript MCP server by default (https://github.com/Ritvik777/mcp-server-salesforce)
SALESFORCE_BACKEND=mcp
SALESFORCE_MCP_COMMAND=npx
SALESFORCE_MCP_ARGS=-y @ritvik777/mcp-server-salesforce
SALESFORCE_CONNECTION_TYPE=User_Password
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_TOKEN=your-salesforce-security-token
SALESFORCE_INSTANCE_URL=your url here
